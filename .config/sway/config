set $mod Mod1

# Borders
default_border pixel 1
hide_edge_borders smart

focus_on_window_activation smart
focus_follows_mouse no
floating_modifier $mod
workspace_auto_back_and_forth yes
popup_during_fullscreen smart

# Floating rules
for_window [title="Preferences$"] floating enable
for_window [title="Event Tester"] floating enable
for_window [app_id="firefox"] inhibit_idle fullscreen # Prevent idle lock/screen off while watching fullscreen videos

# Input
input type:touchpad {
    tap enabled
    dwt enabled
}

input type:keyboard {
    repeat_delay 300
    repeat_rate 40
}

###############################################################################
## Variables                                                                 ##
###############################################################################

set $ws1 "1:code"
set $ws2 "2:browser"
set $ws3 "3:slack"
set $ws4 "4:obsidian"
set $ws5 "5:"
set $ws6 "6:"
set $ws7 "7:files"
set $ws8 "8:discord"
set $ws9 "9:spotify"

# Assign applications to workspaces
# Use `swaymsg -t get_tree` to find app_id (Wayland) or class (XWayland)
assign [app_id="firefox"] $ws2
assign [app_id="firefox_firefox"] $ws2
assign [app_id="[Ss]lack"] $ws3
assign [class="[Ss]lack"] $ws3
assign [app_id="obsidian"] $ws4
assign [class="obsidian"] $ws4
assign [app_id="discord"] $ws8
assign [class="discord"] $ws8
assign [class="[Ss]potify"] $ws9

###############################################################################
## Theme                                                                     ##
###############################################################################

# class                 border    bg       text      indicator  child_border
client.focused          #FF00FF   #000000  #ffffff   #0000ff    #ffffff
client.focused_inactive #44475A   #000000  #ffffff   #44475A    #44475A
client.unfocused        #282A36   #000000  #ffffff   #282A36    #202020
client.urgent           #44475A   #000000  #ffffff   #FF5555    #FF5555
client.placeholder      #282A36   #000000  #ffffff   #282A36    #282A36
client.background       #F8F8F2

###############################################################################
## Keybindings                                                               ##
###############################################################################

bindsym $mod+Return exec /home/emiel/.cargo/bin/alacritty
bindsym $mod+q kill
bindsym $mod+d exec "rofi -show drun"
bindsym $mod+a focus parent
bindsym $mod+shift+d focus child

bindsym $mod+s split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle
bindsym $mod+space floating toggle

# Audio
bindsym --locked XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume --limit 1.0 @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Brightness
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-

# Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Focus (vim-like)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move window (vim-like)
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Move workspace to other monitor
bindsym $mod+Ctrl+h move workspace to output left
bindsym $mod+Ctrl+l move workspace to output right
bindsym $mod+Ctrl+j move workspace to output down
bindsym $mod+Ctrl+k move workspace to output up

# Workspaces
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9

# Screenshot
bindsym $mod+Shift+s exec 'grim -g "$(slurp -d)" - | wl-copy'

# Reload and exit
bindsym $mod+Shift+r reload

# Lock screen
set $Locker swaylock -f -c 141414
bindsym $mod+Escape exec $Locker

set $mode_system System (l) lock, (e) logout, (s) suspend, (h) hibernate, (r) reboot, (Shift+s) shutdown
mode "$mode_system" {
    bindsym l exec $Locker, mode "default"
    bindsym e exec swaymsg exit, mode "default"
    bindsym s exec $Locker && systemctl suspend, mode "default"
    bindsym h exec $Locker && systemctl hibernate, mode "default"
    bindsym r exec systemctl reboot, mode "default"
    bindsym Shift+s exec systemctl poweroff -i, mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+shift+BackSpace mode "$mode_system"

# Resize mode
bindsym $mod+r mode "resize"
mode "resize" {
    bindsym l resize grow width 80 px
    bindsym h resize shrink width 80 px
    bindsym j resize grow height 80 px
    bindsym k resize shrink height 80 px
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

# Move floating windows
bindsym $mod+m mode "move" focus floating
mode "move" {
    bindsym $mod+Tab focus right
    bindsym Left  move left
    bindsym Down  move down
    bindsym Up    move up
    bindsym Right move right
    bindsym h     move left
    bindsym j     move down
    bindsym k     move up
    bindsym l     move right
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+m mode "default"
}

###############################################################################
## Appearance                                                                ##
###############################################################################

bar {
    swaybar_command waybar
}

gaps inner 3

output * bg $HOME/.config/sway/wallpapers/background_otiv.png fill

###############################################################################
## Startup                                                                   ##
###############################################################################

# Idle: lock after 5 min, screen off after 10 min, lock before sleep
exec swayidle -w \
    timeout 300 '$Locker' \
    timeout 600 'swaymsg "output * power off"' \
        resume 'swaymsg "output * power on"' \
    before-sleep '$Locker'

exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

exec /home/emiel/.cargo/bin/alacritty
exec /usr/bin/slack
exec /usr/bin/firefox
