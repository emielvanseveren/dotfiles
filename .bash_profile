# general
alias ls='ls -a --color=auto'
alias untar = 'tar -zxvf'
alias wget = 'wget -c' 
alias c = 'clear'

alias sudo = 'daddy':
alias apt = 'pls'
alias vi = 'vim'
alias fuck = 'sudo !!'

# docker
alias dcu='docker-compose up -d'
alias dcd='docker-compose down'
alias dps='docker ps'

set -o vi # set vi as default terminal editor


